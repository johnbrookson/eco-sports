{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eco-sports.local/schemas/user.json",
  "title": "User",
  "description": "Conta de usuário da plataforma. Um usuário sempre possui um tenant individual próprio e pode participar de N tenants organizacionais via OrganizationMembership.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "individualTenantId",
    "profile",
    "globalRoles",
    "status",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "individualTenantId": {
      "type": "string",
      "description": "Tenant individual (pessoa física) de propriedade do usuário. Criado junto com a conta."
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["firstName", "lastName"],
      "properties": {
        "firstName": { "type": "string", "minLength": 1 },
        "lastName": { "type": "string", "minLength": 1 },
        "preferredName": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": {
          "type": "string",
          "enum": ["female", "male", "non_binary", "prefer_not_to_say", "other"]
        },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "locale": { "type": "string", "description": "Código BCP-47 (ex.: pt-BR, en-US)" },
        "timezone": { "type": "string", "description": "IANA timezone (ex.: America/Sao_Paulo)" }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email"],
      "properties": {
        "email": { "type": "string", "format": "email" },
        "emailVerified": { "type": "boolean" },
        "phone": { "type": "string" },
        "phoneVerified": { "type": "boolean" }
      }
    },
    "globalRoles": {
      "type": "array",
      "description": "Papéis globais do usuário na plataforma. Um mesmo usuário pode acumular papéis (ex.: atleta e profissional career_advisor).",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "athlete",
          "parent_guardian",
          "professional",
          "sponsor",
          "platform_admin"
        ]
      }
    },
    "professionalSpecialties": {
      "type": "array",
      "description": "Obrigatório quando globalRoles contém 'professional'. Um profissional pode ter mais de uma especialidade.",
      "items": {
        "type": "string",
        "enum": [
          "coach",
          "scout",
          "physical_trainer",
          "nutritionist",
          "psychologist",
          "lawyer",
          "career_advisor",
          "video_analyst"
        ]
      }
    },
    "professionalCredentials": {
      "type": "array",
      "description": "Credenciais profissionais (ex.: CREF, OAB, CRP). Relevante para compliance e exibição no marketplace.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "number"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["cref", "oab", "crp", "crn", "crm", "other"]
          },
          "number": { "type": "string" },
          "issuer": { "type": "string" },
          "issuedAt": { "type": "string", "format": "date" },
          "expiresAt": { "type": "string", "format": "date" },
          "verified": { "type": "boolean" },
          "documentUrl": { "type": "string", "format": "uri" }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mfaEnabled": { "type": "boolean" },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "lastLoginIp": { "type": "string" },
        "passwordChangedAt": { "type": "string", "format": "date-time" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pending_verification", "active", "suspended", "deactivated"]
    },
    "isMinor": {
      "type": "boolean",
      "description": "Derivado de profile.birthDate. Se true, operações sensíveis exigem consentimento de um parent_guardian vinculado via GuardianRelationship."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
